ation": "calls", "context": "call", "confidence": "EXTRACTED", "source_file": "/Users/phillipzhang/Work/Web/learn-react/src/lib/db/web-sqlite.ts", "source_location": "L130", "weight": 1.0}], "raw_calls": [{"caller_nid": "db_web_sqlite_webdatabaseservice_init", "callee": "(async () => {\n            try {\n                // \u4f7f\u7528 Vite \u7684 Worker \u5bfc\u5165\u8bed\u6cd5\n                const newWorker = new Worker(\n                    new URL(\"./sqlite-worker.ts\", import.meta.url),\n                    {\n                        type: \"module\",\n                    }\n                )\n\n                newWorker.onmessage = (e) => {\n                    const { id, success, rows, changes, error } = e.data\n                    const promise = this.pendingPromises.get(id)\n\n                    if (promise) {\n                        if (success) {\n                            promise.resolve(rows || { rows: [], changes })\n                        } else {\n                            promise.reject(new Error(error))\n                        }\n                        this.pendingPromises.delete(id)\n                    }\n                }\n\n                newWorker.onerror = (e) => {\n                    console.error(\"WebDatabaseService: Worker error\", e)\n                    // If the worker crashes, we'll null it out so the next call re-inits\n                    if (this.worker === newWorker) {\n                        this.worker = null\n                    }\n                }\n\n                this.worker = newWorker\n            } finally {\n                this.isInitializing = false\n            }\n        })", "is_member_call": false, "source_file": "/Users/phillipzhang/Work/Web/learn-react/src/lib/db/web-sqlite.ts", "source_location": "L20"}, {"caller_nid": "db_web_sqlite_webdatabaseservice_transaction", "callee": "callback", "is_member_call": false, "source_file": "/Users/phillipzhang/Work/Web/learn-react/src/lib/db/web-sqlite.ts", "source_location": "L132"}]}