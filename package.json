{
  "name": "learn-react",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vp dev --host",
    "dev:cloud": "vp dev --host --mode cloud",
    "build": "tsc -b && vp build",
    "lint": "vp lint .",
    "format": "vp fmt \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "preview": "vp preview",
